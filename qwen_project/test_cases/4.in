void solve () {
    int t = 2;

    // Test case 1
    int n1 = 100000;
    int[] arr1 = new int[n1];
    for (int i = 0; i < n1; i++)
        arr1[i] = i % 100;

    // Test case 2
    int n2 = 5;
    int[] arr2 = {1000000000, 1, 1000000000, 1, 1000000000};

    int[][] test_cases = {arr1, arr2};
    int[] ns = {n1, n2};

    for (int k = 0; k < t; k++) {
        int n = ns[k];
        int[] arr = test_cases[k];

        long total = 0;
        foreach (int x in arr)
            total += x;

        if (total % n != 0) {
            stdout.printf("NO\n");
            continue;
        }

        long target = total / n;
        long give = 0;
        long take = 0;

        foreach (int x in arr) {
            if (x > target)
                give += x - target;
            else
                take += target - x;
        }

        stdout.printf("%s\n", give == take ? "YES" : "NO");
    }
}

void main () {
    solve();
}